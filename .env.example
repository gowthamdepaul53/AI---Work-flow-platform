# =============================================================================
# AI Workflow Orchestration Platform — Environment Variables
# Copy to .env and fill in your values. Never commit .env to git.
# =============================================================================

# --- LLM APIs ---
OPENAI_API_KEY=sk-...                        # Required: OpenAI GPT-4 access
HF_TOKEN=hf_...                              # Required: Hugging Face inference API
BIAS_LLM_EVAL=false                          # Set true to use GPT-4 for bias eval (adds cost)

# --- Database ---
DATABASE_URL=postgresql://platform:platform@localhost:5432/platform_db

# --- ChromaDB ---
CHROMA_HOST=localhost
CHROMA_PORT=8001

# --- n8n ---
N8N_ENCRYPTION_KEY=change-me-in-production   # Must be 32+ chars
N8N_WEBHOOK_BASE_URL=http://localhost:5678

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
GRAFANA_PASSWORD=admin

# --- Security ---
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5678
JWT_SECRET=change-me-in-production

# --- Infrastructure (Terraform / GCP) ---
GCP_PROJECT=your-gcp-project-id
GCP_REGION=us-central1
DB_PASSWORD=change-me-in-production
ENVIRONMENT=dev
